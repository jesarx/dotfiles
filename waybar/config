{
    "layer": "bottom",
    "position": "top",
    "height": 32,

    "modules-left": [
        "sway/workspaces",
        "sway/window"
    ],
    "modules-center": [
        "clock"
    ],
    "modules-right": [
        "tray",
        "custom/weather",
        "custom/keyboard-layout",
        "network",
        "backlight",
        "memory",
        "cpu",
        "pulseaudio",
        "battery",
    ],

    "sway/workspaces": {
        "disable-scroll": true,
        "format": "{name}",
        "format-icons": {
            "urgent": "",       // fa-exclamation-circle
            "focused": "",      // nf-oct-dot_fill
            "default": "○"
        }
    },

    "sway/window": {
        "format": "{}",        // fa-window-maximize
        "max-length": 50
    },

    "clock": {
        "format": "{:%H:%M - %a %d/%m}",   // fa-clock
        "tooltip-format": "{:%B %Y}",
        "timezone": "America/Mexico_City",
        "on-click": "alacritty --hold --command cal -y"
    },

    "custom/weather": {
        "format": "{}",       // nf-weather-day_cloudy
        "interval": 300,
        "return-type": "json",
        "exec": "curl -s 'https://wttr.in/19.405958,-99.133457?format=1' | jq --unbuffered --compact-output -M -R '{text:.}'",
        "exec-if": "ping wttr.in -c1",
        "on-click": "alacritty --hold --command curl wttr.in/19.405958,-99.133457"
    },

    "custom/keyboard-layout": {
        "exec": "swaymsg -t get_inputs | grep -m1 'xkb_active_layout_name' | cut -d '\"' -f4 | cut -d ' ' -f1 | cut -c1-2",
        "interval": 10,
        "format": " {}",        // fa-keyboard
        "signal": 1,
        "tooltip": false,
        "on-click": "swaymsg input type:keyboard xkb_switch_layout next"
    },

    "network": {
        "format-wifi": " {essid}",     // fa-wifi
        "format-ethernet": " {ifname}", // fa-sitemap
        "format-disconnected": "⚠",     // warning
        "tooltip-format": "{ifname}: {ipaddr}"
    },

    "backlight": {
        "format": "󰖨 {percent}",        // fa-sun
        "on-scroll-up": "brightnessctl set +5%",
        "on-scroll-down": "brightnessctl set 5%-"
    },

    "memory": {
        "interval": 5,
        "format": " {percentage}",     // nf-dev-ram
        "states": {
            "warning": 70,
            "critical": 90
        }
    },

    "cpu": {
        "interval": 5,
        "format": " {usage}",         // fa-microchip
        "states": {
            "warning": 70,
            "critical": 90
        }
    },

    "pulseaudio": {
        "format": "{icon} {volume}",
        "format-muted": "󰂛",            // fa-volume-mute
        "format-icons": {
            "default": ["", "", ""]  // fa-volume-off, fa-volume-down, fa-volume-up
        },
        "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
        "scroll-step": 5
    },

    "battery": {
        "format": "{icon} {capacity} ",
        "format-discharging": "{icon} {capacity} ",
        "format-icons": [
            "", // fa-battery-empty
            "", // fa-battery-quarter
            "", // fa-battery-half
            "", // fa-battery-three-quarters
            ""  // fa-battery-full
        ],
        "states": {
            "warning": 25,
            "critical": 15
        }
    },

    "tray": {
        "icon-size": 20,
        "spacing": 8
    }
}

